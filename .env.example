# Copy to .env and fill in secrets. Never commit .env.

RA_ENVIRONMENT=dev
RA_LOG_LEVEL=INFO
RA_LOG_FORMAT=console

RA_POSTGRES_DSN=postgresql+asyncpg://repo_assistant:repo_assistant@localhost:5432/repo_assistant
RA_REDIS_DSN=redis://localhost:6379/0
RA_QDRANT_URL=http://localhost:6333

RA_ANTHROPIC_API_KEY=
RA_VOYAGE_API_KEY=
RA_GITHUB_TOKEN=
