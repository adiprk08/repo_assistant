# Copy to .env and fill in secrets. Never commit .env.

RA_ENVIRONMENT=dev
RA_LOG_LEVEL=INFO
RA_LOG_FORMAT=console

RA_POSTGRES_DSN=postgresql+asyncpg://repo_assistant:repo_assistant@localhost:5432/repo_assistant
RA_REDIS_DSN=redis://localhost:6379/0
RA_QDRANT_URL=http://localhost:6333

RA_ANTHROPIC_API_KEY=
RA_VOYAGE_API_KEY=
RA_GITHUB_TOKEN=

# Web auth via GitHub OAuth (docs/adr/0023). Register a GitHub OAuth App with
# callback http://localhost:3000/api/auth/github/callback and set both here; unset
# => web login is unavailable (API-key / local-user access still works).
RA_GITHUB_OAUTH_CLIENT_ID=
RA_GITHUB_OAUTH_CLIENT_SECRET=
# Where the browser app is served (OAuth returns here; cookie is scoped to it).
RA_WEB_BASE_URL=http://localhost:3000
# RA_SESSION_TTL_DAYS=14
# Set true when serving the app over HTTPS in production.
# RA_SESSION_COOKIE_SECURE=false
# RA_REQUIRE_AUTH=true
